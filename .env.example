# Banking Platform - Environment Variables
# Copy this file to .env and fill in real values before running docker-compose

# =========== Database Passwords ===========
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_AUTH_PASSWORD=auth_secret_change_me
MYSQL_USER_PASSWORD=user_secret_change_me
MYSQL_ACCOUNT_PASSWORD=account_secret_change_me
MYSQL_TRANSACTION_PASSWORD=txn_secret_change_me
MYSQL_BENEFICIARY_PASSWORD=ben_secret_change_me
MYSQL_NOTIFICATION_PASSWORD=notif_secret_change_me
MYSQL_FRAUD_PASSWORD=fraud_secret_change_me
MYSQL_AUDIT_PASSWORD=audit_secret_change_me

# =========== Redis ===========
REDIS_PASSWORD=redis_secret_change_me

# =========== JWT ===========
# Generate with: openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# =========== Infrastructure ===========
CONFIG_SERVER_PASSWORD=config_secret_change_me
EUREKA_PASSWORD=eureka_secret_change_me

# =========== Email (SMTP) ===========
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_smtp_app_password

# =========== Monitoring ===========
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_change_me
